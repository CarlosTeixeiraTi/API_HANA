module.exports = (sequelize, DataTypes) => {
    const Veiculo = sequelize.define('Veiculo', {
        veiculo: {
            primaryKey: true,
            type: DataTypes.STRING(20),
            allowNull: false
        },
        veiculoEquipamentos: {
            type: DataTypes.JSON,
            allowNull: false
        },
        dataAtualizacao: {
            type: DataTypes.DATE,
            allowNull: false
        }
    }, {
        // define the table's name
        tableName: 'Veiculo'
    });

    return Veiculo;
}